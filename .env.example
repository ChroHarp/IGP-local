# This file is documentation only. Configure these values as process or service
# environment variables; do not commit a real .env file.
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-before-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Configure these only after the school creates its own Google OAuth web client.
# Keep the secret in the service environment, never in Git or Django Admin.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
